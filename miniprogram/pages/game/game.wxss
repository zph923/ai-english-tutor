/* pages/game/game.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a2a4a 0%, #0f1a3a 100%);
  padding: 30rpx;
}

.header {
  text-align: center;
  margin-bottom: 30rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #ffd700;
  text-shadow: 0 0 20rpx #ffd700;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: #aaa;
}

.screen {
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.section {
  margin-bottom: 35rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #00d4ff;
  text-shadow: 0 0 10rpx #00d4ff;
  margin-bottom: 20rpx;
  text-align: center;
}

/* 角色卡片 */
.character-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.character-card {
  background: linear-gradient(135deg, #1a2a3a 0%, #2a3a5a 100%);
  border: 3rpx solid #445;
  border-radius: 20rpx;
  padding: 20rpx 10rpx;
  text-align: center;
  transition: all 0.3s;
  position: relative;
}

.character-card:active {
  transform: scale(0.95);
}

.character-card.selected {
  border-color: #ffd700;
  box-shadow: 0 0 30rpx rgba(255, 215, 0, 0.7);
  transform: scale(1.05);
}

.character-card.selected::after {
  content: '✓';
  position: absolute;
  top: 10rpx;
  right: 15rpx;
  font-size: 32rpx;
  color: #ffd700;
}

.character-card.locked {
  opacity: 0.6;
}

.character-image {
  width: 100rpx;
  height: 100rpx;
  margin: 0 auto 15rpx;
  border-radius: 15rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.3);
  border: 3rpx solid;
  position: relative;
}

.character-emoji {
  font-size: 60rpx;
}

.lock-icon {
  position: absolute;
  font-size: 40rpx;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.character-name {
  display: block;
  font-size: 24rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.character-desc {
  display: block;
  font-size: 20rpx;
  color: #888;
}

/* 题型选择 */
.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding: 0 10rpx;
}

.panel-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #00d4ff;
}

.back-small-btn {
  background: transparent;
  color: #00d4ff;
  border: 2rpx solid #00d4ff;
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  border-radius: 30rpx;
}

.placeholder {
  width: 100rpx;
}

.topic-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.topic-card {
  background: linear-gradient(135deg, #2a3a5a 0%, #1a2a4a 100%);
  border: 3rpx solid #445;
  border-radius: 20rpx;
  padding: 25rpx 15rpx;
  text-align: center;
  position: relative;
  transition: all 0.3s;
}

.topic-card:active {
  transform: scale(0.95);
}

.topic-card.selected {
  border-color: #66ff66 !important;
  background: linear-gradient(135deg, #2a5a3a 0%, #1a4a2a 100%) !important;
  box-shadow: 0 0 30rpx rgba(102, 255, 102, 0.8) !important;
  transform: scale(1.05);
}

.topic-card.selected .topic-name {
  color: #66ff66;
  font-weight: bold;
}

.topic-card.selected .topic-icon {
  border-color: #66ff66;
}

.topic-icon {
  width: 80rpx;
  height: 80rpx;
  margin: 0 auto 15rpx;
  border-radius: 15rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
  background: rgba(0, 0, 0, 0.3);
}

.topic-name {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.topic-count {
  display: block;
  font-size: 20rpx;
  color: #888;
}

.topic-check {
  position: absolute;
  top: 10rpx;
  right: 15rpx;
  font-size: 40rpx;
  color: #66ff66;
  animation: checkPop 0.3s ease-out;
}

@keyframes checkPop {
  0% { transform: scale(0); opacity: 0; }
  50% { transform: scale(1.3); }
  100% { transform: scale(1); opacity: 1; }
}

/* 难度选择 */
.difficulty-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 15rpx;
}

.difficulty-card {
  background: linear-gradient(135deg, #2a3a5a 0%, #1a2a4a 100%);
  border: 3rpx solid #445;
  border-radius: 20rpx;
  padding: 20rpx 10rpx;
  text-align: center;
}

.difficulty-card:active {
  transform: scale(0.95);
}

.difficulty-card.selected {
  border-color: #ffd700;
  box-shadow: 0 0 20rpx rgba(255, 215, 0, 0.5);
}

.difficulty-icon {
  font-size: 50rpx;
  display: block;
  margin-bottom: 10rpx;
}

.difficulty-name {
  display: block;
  font-size: 24rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 5rpx;
}

.difficulty-desc {
  display: block;
  font-size: 18rpx;
  color: #888;
  margin-bottom: 8rpx;
}

.difficulty-stars {
  display: block;
  font-size: 20rpx;
  color: #ffd700;
}

/* 题目数量选择 */
.count-selector {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

.count-card {
  background: linear-gradient(135deg, #2a3a5a 0%, #1a2a4a 100%);
  border: 3rpx solid #445;
  border-radius: 15rpx;
  padding: 20rpx 30rpx;
  text-align: center;
  min-width: 100rpx;
}

.count-card:active {
  transform: scale(0.95);
}

.count-card.selected {
  border-color: #00d4ff;
  box-shadow: 0 0 20rpx rgba(0, 212, 255, 0.5);
}

.count-number {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.count-label {
  display: block;
  font-size: 20rpx;
  color: #888;
}

/* 总结框 */
.summary-box {
  background: rgba(0, 212, 255, 0.1);
  border: 2rpx solid #00d4ff;
  border-radius: 15rpx;
  padding: 20rpx;
  text-align: center;
  margin-bottom: 30rpx;
}

.summary-box text {
  font-size: 26rpx;
  color: #00d4ff;
}

/* 按钮组 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  justify-content: center;
  margin-top: 30rpx;
}

.action-btn {
  background: linear-gradient(135deg, #3a4a6a 0%, #2a3a5a 100%);
  color: #fff;
  border: none;
  padding: 25rpx 50rpx;
  font-size: 28rpx;
  border-radius: 100rpx;
  font-weight: bold;
}

.action-btn:active {
  transform: scale(0.95);
}

.action-btn.primary {
  background: linear-gradient(135deg, #00d4ff 0%, #0088cc 100%);
  box-shadow: 0 10rpx 30rpx rgba(0, 212, 255, 0.5);
}

.action-btn.primary[disabled] {
  background: #445;
  box-shadow: none;
}

.shop-btn {
  background: linear-gradient(135deg, #ffd700 0%, #ffaa00 100%);
  color: #000;
}

/* 战斗场景 */
.battle-scene {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(0, 0, 0, 0.4);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  border: 2rpx solid #334;
}

.fighter {
  flex: 1;
  text-align: center;
}

.fighter-image {
  width: 140rpx;
  height: 140rpx;
  margin: 0 auto 20rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.3);
  border: 4rpx solid;
}

.fighter-emoji {
  font-size: 80rpx;
}

.health-bar {
  width: 200rpx;
  height: 40rpx;
  background: #222;
  border-radius: 20rpx;
  margin: 15rpx auto;
  overflow: hidden;
  border: 3rpx solid #444;
}

.health-fill {
  height: 100%;
  background: linear-gradient(90deg, #ff3333 0%, #ff6666 100%);
  transition: width 0.5s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-weight: bold;
  font-size: 24rpx;
}

.health-fill.good {
  background: linear-gradient(90deg, #33ff33 0%, #66ff66 100%);
}

.health-fill.warning {
  background: linear-gradient(90deg, #ffaa00 0%, #ffcc00 100%);
}

.health-fill.danger {
  background: linear-gradient(90deg, #ff3333 0%, #ff6666 100%);
}

.fighter-name {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  color: #fff;
  margin-top: 15rpx;
}

.vs-symbol {
  font-size: 50rpx;
  color: #ff4444;
  font-weight: bold;
  margin: 0 40rpx;
  text-shadow: 0 0 30rpx #ff4444;
}

/* 进度 */
.progress {
  text-align: center;
  color: #00d4ff;
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

/* 题目区域 */
.question-area {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  padding: 30rpx;
  border: 2rpx solid #334;
}

.question-type-badge {
  display: inline-block;
  padding: 10rpx 25rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 20rpx;
}

.question-text {
  font-size: 36rpx;
  color: #fff;
  text-align: center;
  margin-bottom: 30rpx;
  line-height: 1.6;
  font-weight: bold;
}

.options {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.option-btn {
  background: linear-gradient(135deg, #3a4a6a 0%, #2a3a5a 100%);
  color: #fff;
  border: 3rpx solid #556;
  padding: 30rpx 20rpx;
  font-size: 28rpx;
  border-radius: 20rpx;
  font-weight: bold;
}

.option-btn:active {
  background: linear-gradient(135deg, #4a5a7a 0%, #3a4a6a 100%);
  border-color: #00d4ff;
}

/* 攻击动画 */
.attack-overlay {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 1000;
  pointer-events: none;
}

.attack-emoji {
  font-size: 200rpx;
  animation: attackAnim 0.8s ease-out;
}

@keyframes attackAnim {
  0% { opacity: 1; transform: translate(-50%, -50%) scale(0.3) rotate(0deg); }
  50% { opacity: 1; transform: translate(-50%, -50%) scale(1.3) rotate(180deg); }
  100% { opacity: 0; transform: translate(-50%, -50%) scale(2) rotate(360deg); }
}

/* 结果界面 */
.result-screen {
  text-align: center;
}

.result-emoji {
  font-size: 150rpx;
  margin-bottom: 30rpx;
  animation: bounce 1s infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-30rpx); }
}

.result-title {
  font-size: 48rpx;
  color: #ffd700;
  text-shadow: 0 0 30rpx #ffd700;
  margin-bottom: 40rpx;
}

.result-title.lose {
  color: #ff4444;
  text-shadow: 0 0 30rpx #ff4444;
}

.stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.stat-box {
  background: rgba(0, 0, 0, 0.3);
  padding: 25rpx;
  border-radius: 20rpx;
  border: 2rpx solid #334;
}

.stat-number {
  display: block;
  font-size: 50rpx;
  font-weight: bold;
  color: #00d4ff;
  margin-bottom: 10rpx;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #aaa;
}

.summary {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  border: 2rpx solid #334;
  max-height: 400rpx;
  overflow-y: auto;
}

.summary-title {
  font-size: 32rpx;
  color: #00d4ff;
  margin-bottom: 20rpx;
  text-align: center;
}

.summary-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.summary-item {
  background: rgba(0, 0, 0, 0.3);
  padding: 20rpx;
  border-radius: 15rpx;
  border-left: 5rpx solid #ff4444;
  text-align: left;
}

.question-text-small {
  display: block;
  font-size: 26rpx;
  color: #fff;
  margin-bottom: 10rpx;
  font-weight: bold;
}

.your-answer {
  display: block;
  font-size: 24rpx;
  color: #ff6666;
  margin-bottom: 8rpx;
}

.correct-answer {
  display: block;
  font-size: 24rpx;
  color: #66ff66;
}

.perfect-text {
  display: block;
  font-size: 32rpx;
  color: #66ff66;
  text-align: center;
}

.result-buttons {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 响应式 */
@media (max-width: 750rpx) {
  .character-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .topic-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .difficulty-grid {
    grid-template-columns: repeat(3, 1fr);
  }

  .options {
    grid-template-columns: 1fr;
  }

  .battle-scene {
    flex-direction: column;
    gap: 30rpx;
  }

  .vs-symbol {
    margin: 20rpx 0;
  }

  .stats {
    grid-template-columns: 1fr;
  }

  .action-buttons {
    flex-direction: column;
  }
}
