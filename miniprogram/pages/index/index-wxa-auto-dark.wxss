@media (prefers-color-scheme: dark) {
    .title {
        color: rgb(36, 117, 187);
    }

    .subtitle {
        color: rgb(99, 99, 99);
    }

    .chat-area {
        background: rgb(24, 24, 24);
    }

    .message {
        background: rgb(17, 17, 17);
    }

    .message.welcome {
        background: rgb(0, 0, 0);
        color: rgb(17, 17, 17);
    }

    .message.user {
        background: rgb(18, 30, 38);
    }

    .message.ai {
        background: rgb(17, 17, 17);
    }

    .message.loading {
        background: rgb(28, 28, 28);
    }

    .speak-btn {
        background: rgb(36, 117, 187);
        color: rgb(17, 17, 17);
    }

    .speak-btn.playing {
        background: rgb(179, 34, 50);
    }

    @keyframes pulse {
        0%, 100% {
            opacity: 1;
        }

        50% {
            opacity: 0.6;
        }
    }

    @keyframes dots {
        0%, 20% {
            content: '';
        }

        40% {
            content: '.';
        }

        60% {
            content: '..';
        }

        80%, 100% {
            content: '...';
        }
    }

    .voice-btn {
        background: rgb(24, 24, 24);
        color: rgb(149, 149, 149);
    }

    .voice-btn.recording {
        background: rgb(215, 12, 40);
        color: rgb(17, 17, 17);
    }

    .clear-btn {
        background: rgb(24, 24, 24);
        color: rgb(149, 149, 149);
    }

    .input {
        border: rgb(0, 0, 0);
    }

    .submit-btn {
        background: rgb(36, 117, 187);
        color: rgb(17, 17, 17);
    }

    .submit-btn.disabled {
        background: rgb(55, 55, 55);
    }
}
