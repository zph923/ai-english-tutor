<view class="container">
  <view class="header">
    <text class="title">🤖 AI 口语陪练</text>
    <text class="subtitle">随时随地练习英语</text>
  </view>

  <view class="chat-area">
    <!-- 欢迎消息 -->
    <view class="message welcome" wx:if="{{chatHistory.length === 0}}">
      <text>{{welcomeMessage}}</text>
    </view>
    
    <!-- 聊天记录 -->
    <view class="message {{item.type}}" wx:for="{{chatHistory}}" wx:key="id">
      <view class="message-avatar">{{item.type === 'user' ? '👤' : '🤖'}}</view>
      <view class="message-content-wrapper">
        <view class="message-content">{{item.content}}</view>
        
        <!-- AI 消息的播放按钮 -->
        <view class="message-actions" wx:if="{{item.type === 'ai'}}">
          <button class="speak-btn {{isPlaying && currentPlayingId === item.id ? 'playing' : ''}}" bindtap="speak" data-text="{{item.content}}" data-id="{{item.id}}">
            {{isPlaying && currentPlayingId === item.id ? '🔇 停止' : '🔊 播放'}}
          </button>
        </view>
      </view>
    </view>
    
    <!-- 加载中 -->
    <view class="message ai loading" wx:if="{{loading}}">
      <view class="message-avatar">🤖</view>
      <view class="message-content">
        <text class="loading-dots">思考中</text>
      </view>
    </view>
  </view>

  <view class="input-area">
    <button class="voice-btn {{isRecording ? 'recording' : ''}}" bindtap="onStartRecord">
      {{isRecording ? '🔴 停止' : '🎤 语音'}}
    </button>
    <input 
      class="input" 
      placeholder="输入你想练习的话题..." 
      value="{{inputValue}}"
      bindinput="onInput"
      confirm-type="send"
      bindconfirm="onSubmit"
    />
    <button class="submit-btn {{loading ? 'disabled' : ''}}" bindtap="onSubmit" disabled="{{loading}}">
      {{loading ? '发送中...' : '发送'}}
    </button>
  </view>
</view>
