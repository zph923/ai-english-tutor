/* pages/shop/shop.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a2a4a 0%, #0f1a3a 100%);
  padding: 30rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffd700;
  text-shadow: 0 0 20rpx #ffd700;
}

.back-btn {
  background: transparent;
  color: #00d4ff;
  border: 2rpx solid #00d4ff;
  padding: 15rpx 30rpx;
  font-size: 28rpx;
  border-radius: 50rpx;
}

/* 付费套餐 */
.packages {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.package-card {
  background: linear-gradient(135deg, #2a3a5a 0%, #1a2a4a 100%);
  border: 3rpx solid #445;
  border-radius: 20rpx;
  padding: 25rpx 15rpx;
  text-align: center;
  position: relative;
}

.package-card.bundle {
  border-color: #ffd700;
  box-shadow: 0 0 30rpx rgba(255, 215, 0, 0.5);
}

.package-icon {
  font-size: 60rpx;
  margin-bottom: 15rpx;
}

.package-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.package-desc {
  font-size: 22rpx;
  color: #888;
  margin-bottom: 15rpx;
}

.package-price {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5rpx;
}

.price {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffd700;
}

.original {
  font-size: 20rpx;
  color: #666;
  text-decoration: line-through;
}

.package-tag {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  background: #ff4444;
  color: #fff;
  font-size: 20rpx;
  padding: 5rpx 10rpx;
  border-radius: 10rpx;
}

/* 角色列表 */
.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #00d4ff;
  text-shadow: 0 0 10rpx #00d4ff;
  margin-bottom: 20rpx;
}

.character-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.character-item {
  background: linear-gradient(135deg, #2a3a5a 0%, #1a2a4a 100%);
  border: 3rpx solid #445;
  border-radius: 20rpx;
  padding: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.character-item.unlocked {
  border-color: #66ff66;
}

.character-item.locked {
  border-color: #ff6666;
}

.character-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.character-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 15rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.3);
  border: 3rpx solid;
  flex-shrink: 0;
}

.character-emoji {
  font-size: 60rpx;
}

.character-details {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.character-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
}

.character-desc {
  font-size: 24rpx;
  color: #888;
}

.character-skill {
  font-size: 22rpx;
  color: #00d4ff;
}

.character-status {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.status-tag {
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.status-tag.free {
  background: #66ff66;
  color: #006600;
}

.status-tag.unlocked {
  background: #6699ff;
  color: #fff;
}

.unlock-btn {
  background: linear-gradient(135deg, #ffd700 0%, #ffaa00 100%);
  color: #000;
  border: none;
  padding: 15rpx 30rpx;
  font-size: 26rpx;
  font-weight: bold;
  border-radius: 50rpx;
}

/* 恢复购买 */
.restore-section {
  text-align: center;
  margin-bottom: 30rpx;
}

.restore-btn {
  background: transparent;
  color: #00d4ff;
  border: 2rpx solid #00d4ff;
  padding: 20rpx 50rpx;
  font-size: 28rpx;
  border-radius: 50rpx;
}

/* 说明 */
.tips {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  padding: 25rpx;
  border: 2rpx solid #334;
}

.tips-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #ffd700;
  margin-bottom: 15rpx;
}

.tip-item {
  font-size: 24rpx;
  color: #aaa;
  margin-bottom: 10rpx;
}

/* 响应式 */
@media (max-width: 750rpx) {
  .packages {
    grid-template-columns: 1fr;
  }
}
